              "host": ["{{base_url}}"],
              "path": ["api", "v1", "exercises"]
            },
            "description": "Create a new custom exercise. Only visible to the user who created it"
          }
        },
        {
          "name": "Update Exercise",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Exercise Name\",\n  \"description\": \"Updated description\",\n  \"type\": \"USER\",\n  \"disciplineId\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/exercises/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "exercises", "1"]
            },
            "description": "Update an exercise. Only the creator can update it. Replace '1' with exercise ID"
          }
        },
        {
          "name": "Delete Exercise",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1",
                "type": "text"

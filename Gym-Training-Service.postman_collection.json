{
  "info": {
    "_postman_id": "gym-training-service-2025",
    "name": "Gym Training Service API",
    "description": "Collection for testing Gym Training Service endpoints\n\nBase URL: http://localhost:8082\n\nHeaders required for all requests:\n- X-User-Id: User identifier (numeric)\n- Content-Type: application/json",

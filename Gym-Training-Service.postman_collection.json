              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Custom Push-up Variation\",\n  \"description\": \"Diamond push-ups for tricep focus\",\n  \"type\": \"USER\",\n  \"disciplineId\": 1\n}"
            },
